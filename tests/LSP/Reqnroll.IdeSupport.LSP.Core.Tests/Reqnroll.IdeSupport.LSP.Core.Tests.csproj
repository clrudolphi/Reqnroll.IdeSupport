<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>../../../reqnroll.snk</AssemblyOriginatorKeyFile>
    <NoWarn>VSTHRD200</NoWarn>
    <!-- VSTHRD200: Test methods don't require "Async" suffix convention -->
  </PropertyGroup>

  <!-- The two deferred files below are the only ones needing MockableDiscoveryService/StubIdeScope
       from Reqnroll.VisualStudio.VsxStubs (a net481 WPF project referencing the VSSDK), which is why
       this project doesn't reference VsxStubs at all — every other test only needs the lightweight,
       dependency-free StubGherkinTextSnapshot from Reqnroll.IdeSupport.LSP.TestStubs below. Un-deferring
       either file means adding a VsxStubs ProjectReference back (and its net481 restore cost) alongside
       the NU1702 NoWarn for that cross-TFM ProjectReference. -->
  <ItemGroup Label="Deferred - depends on VS connector not yet ported">
    <!-- ProjectBindingRegistryCache depends on connector discovery pipeline -->
    <Compile Remove="Bindings\ProjectBindingRegistryCacheTests.cs" />
    <!-- MockableDiscoveryService / StubIdeScope used in Reprocess tests depend on connector + WPF stubs -->
    <Compile Remove="Bindings\ReprocessStepDefinitionFileTests.cs" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="ApprovalTestData\**" />
    <Content Include="ApprovalTestData\**" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ApprovalTests" Version="5.9.0" />
    <PackageReference Include="AwesomeAssertions" Version="9.4.0" />
    <PackageReference Include="MessagePack" Version="2.5.302" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.3.0" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="NSubstitute" Version="5.3.0" />
    <PackageReference Include="System.Data.SqlClient" Version="4.8.6" />
    <PackageReference Include="System.Diagnostics.EventLog" Version="7.0.0" />
    <PackageReference Include="System.IO.Abstractions.TestingHelpers" Version="22.1.1" />
    <PackageReference Include="xunit" Version="2.9.0" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Xunit.SkippableFact" Version="1.4.13" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../../src/Core/Reqnroll.IdeSupport.Common/Reqnroll.IdeSupport.Common.csproj" />
    <ProjectReference Include="../../../src/LSP/Reqnroll.IdeSupport.LSP.Core/Reqnroll.IdeSupport.LSP.Core.csproj" />
    <ProjectReference Include="../Reqnroll.IdeSupport.LSP.TestStubs/Reqnroll.IdeSupport.LSP.TestStubs.csproj" />
  </ItemGroup>
</Project>
