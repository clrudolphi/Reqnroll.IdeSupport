// src/Rider/.devcontainer/devcontainer.json
{
  "name": "reqnroll-rider-plugin",
  "build": {
    "dockerfile": "../docker/dev.Dockerfile",
    "context": ".."
  },
  "containerEnv": {
    // WSLg's DISPLAY is typically ":0" — confirm with `echo $DISPLAY`
    // in Step 1 and adjust if yours differs.
    "DISPLAY": ":0"
  },
  "mounts": [
    // Docker Desktop's docker.exe is Windows-native, so bind-mount sources
    // must be paths Windows can resolve — a bare "/mnt/wslg" fails with
    // "bind source path does not exist". \\wsl.localhost\<distro>\... is
    // the UNC form that actually works. Update "Ubuntu" below if your
    // distro is named differently.
    "source=\\\\wsl.localhost\\Ubuntu\\mnt\\wslg,target=/mnt/wslg,type=bind",
    "source=reqnroll-gradle-cache,target=/root/.gradle,type=volume",
    // Scratch home for ad hoc sample Reqnroll .NET projects created while manually
    // testing the plugin in a running Rider sandbox. Deliberately a named volume
    // outside the repo bind mount (rather than a gitignored folder under
    // /workspaces/Reqnroll.IdeSupport): it persists across "Rebuild Container" the
    // same way the repo itself does, but stays completely outside the git working
    // tree — no risk of `git status` noise, `git clean` wiping test projects, or one
    // slipping into a commit by accident. Sits alongside the repo checkout under
    // /workspaces so it's just as easy to reach from Rider's Open dialog.
    "source=reqnroll-rider-samples,target=/workspaces/rider-samples,type=volume"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "fwcd.kotlin"
      ]
    }
  }
}