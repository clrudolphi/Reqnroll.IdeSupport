<idea-plugin>
  <id>com.reqnroll.idesupport</id>
  <name>Reqnroll</name>
  <vendor url="https://github.com/reqnroll/Reqnroll.IdeSupport">Reqnroll</vendor>

  <description>
<![CDATA[
Experimental Reqnroll language support for Rider: Gherkin feature files and C# step-binding
navigation, backed by the Reqnroll.IdeSupport LSP server.
]]>
  </description>

  <depends>com.intellij.modules.platform</depends>
  <depends>com.intellij.modules.rider</depends>
  <!-- Not `com.intellij.modules.lsp` — that module ID isn't registered in Rider's
       distribution (confirmed via runIde: "requires plugin 'com.intellij.modules.lsp'
       to be installed" with no such plugin found). The com.intellij.platform.lsp.api.*
       classes used below are part of the core platform artifact and don't sit behind
       a separate module dependency. -->


  <extensions defaultExtensionNs="com.intellij">
    <platform.lsp.serverSupportProvider
        implementation="com.reqnroll.ide.rider.lsp.ReqnrollLspServerSupportProvider" />

    <fileType
        name="Reqnroll Feature"
        implementationClass="com.reqnroll.ide.rider.ReqnrollFeatureFileType"
        fieldName="INSTANCE"
        language="Reqnroll Feature"
        extensions="feature" />

    <postStartupActivity implementation="com.reqnroll.ide.rider.lsp.project.ReqnrollRunnableProjectsListener" />
    <postStartupActivity implementation="com.reqnroll.ide.rider.lsp.project.ReqnrollProjectFilesSync" />
    <postStartupActivity implementation="com.reqnroll.ide.rider.lsp.project.ReqnrollDocumentActivationSync" />

    <!-- The built-in CommentByLineComment action (Ctrl+/) is a MultiCaretCodeInsightAction that
         hardcodes its own handler and gates on LanguageCommenters.forLanguage finding a Commenter
         for the file — .feature has neither a PSI language nor a registered Commenter, so it's a
         no-op there. ReqnrollToggleCommentAction (in the <actions> block below) is bound to the
         same default keystroke; this promoter suppresses the built-in action from that keystroke's
         candidate list specifically for .feature files so ours fires instead. See
         ReqnrollToggleCommentAction's doc comment for why decorating an EditorActionHandler (the
         first approach tried) doesn't work for this particular built-in action. -->
    <actionPromoter implementation="com.reqnroll.ide.rider.commenting.ReqnrollCommentTogglePromoter" />

    <!-- Rider's generic LSP client has no rendering-side consumer for textDocument/codeLens or
         textDocument/inlayHint at all (confirmed by decompiling — only capability-name
         bookkeeping exists in com.intellij.platform.lsp.impl.LspDynamicCapabilities). Both
         requests are called directly (ReqnrollRequestSender) and rendered through IntelliJ's
         own native extension points instead. -->
    <codeInsight.codeVisionProvider implementation="com.reqnroll.ide.rider.codevision.StepUsagesCodeVisionProvider" />

    <!-- Not a codeInsight.declarativeInlayProvider: that EP dispatches by PSI language, but
         .feature files have no ParserDefinition registered (see
         ReqnrollFeatureInlayHintsController's doc comment for why that silently breaks
         language-scoped routing). Managed manually via Editor.inlayModel instead. -->
    <editorFactoryListener implementation="com.reqnroll.ide.rider.inlayhints.ReqnrollFeatureInlayHintsController" />

    <!-- No generic-client rendering for textDocument/foldingRange either (confirmed via bytecode
         inspection of LspServerDescriptor for issue #162: no lspFoldingRangeSupport opt-in and no
         LspFoldingRangeSupport customization class exist at all, unlike lspGoToDefinitionSupport).
         Same "manage it manually" approach as the inlay hints controller above. -->
    <editorFactoryListener implementation="com.reqnroll.ide.rider.folding.ReqnrollFeatureFoldingController" />

    <!-- Rider's generic LSP client has no bridge for textDocument/onTypeFormatting at all (unlike
         whole-document formatting's LspFormattingService — see
         ReqnrollLspServerDescriptor.lspFormattingSupport), so `|`-triggered table-column
         realignment is driven manually, same reasoning as the codeVision/inlay entries above. -->
    <typedHandler implementation="com.reqnroll.ide.rider.formatting.ReqnrollFeatureOnTypeFormattingHandler" />
  </extensions>

  <actions>
    <group id="Reqnroll.ActionGroup" text="Reqnroll" popup="true">
      <add-to-group group-id="ToolsMenu" anchor="last" />

      <action id="Reqnroll.FindUnusedStepDefinitions"
          class="com.reqnroll.ide.rider.actions.FindUnusedStepDefinitionsAction"
          text="Find Unused Step Definitions"
          description="Scans the workspace for step-definition bindings with no matching steps in any feature file" />

      <!-- Mirrors VS Code's editor/context "Find Step Usages" entry (when editorLangId ==
           csharp) — the action's own update() restricts visibility to .cs files, so it's safe to
           also add it to the editor context menu below without a declarative language condition. -->
      <action id="Reqnroll.FindStepUsages"
          class="com.reqnroll.ide.rider.actions.FindStepUsagesAction"
          text="Find Step Usages"
          description="Finds feature-file steps that use the step-definition binding at the caret">
        <add-to-group group-id="EditorPopupMenu" anchor="last" />
      </action>

      <!-- Mirrors VS's GoToHooksCommand / VS Code's "Go to Hooks" editor context entry — the
           action's own update() restricts visibility to .feature files, so it's safe to also add
           it to the editor context menu below without a declarative language condition. -->
      <action id="Reqnroll.GoToHooks"
          class="com.reqnroll.ide.rider.actions.GoToHooksAction"
          text="Go to Hooks"
          description="Navigates to the hook bindings applicable at the caret position in a feature file">
        <add-to-group group-id="EditorPopupMenu" anchor="last" />
      </action>

      <!-- Bound to the platform's own default Ctrl+/ keystroke — ReqnrollCommentTogglePromoter
           (registered under <extensions> above) suppresses the built-in CommentByLineComment
           action from that keystroke for .feature files, so this one fires instead. The action's
           own update() also restricts visibility to .feature files, matching the other actions
           here, so it's safe to add to the editor context menu unconditionally too. -->
      <action id="Reqnroll.ToggleComment"
          class="com.reqnroll.ide.rider.commenting.ReqnrollToggleCommentAction"
          text="Comment/Uncomment"
          description="Toggles # comments on the selected line(s) of a feature file">
        <add-to-group group-id="EditorPopupMenu" anchor="last" />
        <keyboard-shortcut keymap="$default" first-keystroke="ctrl SLASH" />
      </action>

      <!-- Rename Step (issue #160), .feature side. Safe to claim Shift+F6 outright: no PSI
           language is registered for Gherkin in this plugin, so nothing else (native or
           otherwise) is bound to that shortcut for .feature files. -->
      <action id="Reqnroll.RenameFeatureStep"
          class="com.reqnroll.ide.rider.actions.RenameFeatureStepAction"
          text="Rename Step"
          description="Renames a step's expression across the feature file and its C# binding">
        <add-to-group group-id="EditorPopupMenu" anchor="last" />
        <keyboard-shortcut keymap="$default" first-keystroke="shift F6" />
      </action>

      <!-- Rename Step (issue #160), .cs side. Deliberately no keyboard shortcut: Rider's native
           Shift+F6 rename already owns that shortcut for ordinary C# symbols, and this action's
           update() can't cheaply tell "caret is on a step attribute" from "caret is on any other
           C# identifier" to safely take it over. Context-menu only, distinct text from the
           native "Rename" entry already in that menu. -->
      <action id="Reqnroll.RenameCSharpStep"
          class="com.reqnroll.ide.rider.actions.RenameCSharpStepAction"
          text="Rename Step (Reqnroll)"
          description="Renames the step-definition binding's expression across this attribute and the feature file">
        <add-to-group group-id="EditorPopupMenu" anchor="last" />
      </action>
    </group>
  </actions>
</idea-plugin>
