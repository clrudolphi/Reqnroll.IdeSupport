<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">

  <PropertyGroup>
    <TargetFramework>net481</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <LangVersion>10.0</LangVersion>
    <RootNamespace>Reqnroll.VisualStudio.Wizards</RootNamespace>
    <AssemblyName>Reqnroll.VisualStudio.Wizards</AssemblyName>
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>..\reqnroll.snk</AssemblyOriginatorKeyFile>
  </PropertyGroup>

  <!--
    VS SDK references are ONLY needed by the VsIntegration layer.
    All WPF UI lives in Reqnroll.VisualStudio.Wizards.UI.
    All VS-SDK-free logic lives in Reqnroll.VisualStudio.Wizards.Core.

  -->

  <ItemGroup>
    <ProjectReference Include="..\Reqnroll.VisualStudio.VSSDKIntegration\Reqnroll.VisualStudio.VSSDKIntegration.csproj" />
    <ProjectReference Include="..\Reqnroll.VisualStudio.Wizards.Core\Reqnroll.VisualStudio.Wizards.Core.csproj" />
    <ProjectReference Include="..\Reqnroll.VisualStudio.Wizards.UI\Reqnroll.VisualStudio.Wizards.UI.csproj" />
  </ItemGroup>

</Project>
